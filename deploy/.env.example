# Harvester 서버의 deploy/.env 로 복사해서 사용.
# 최초 배포 전 SSH 로 접속해 이 파일을 서버 ~/hope/deploy/.env 에 두고 chmod 600.
# rsync 는 deploy/.env 를 제외하도록 되어 있어 실수로 덮어써지지 않는다.

# --- 앱 동작 ---
# 세션 토큰 유효 시간
HOPE_TOKEN_TTL_HOURS=24

# pino 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info

# CORS 허용 오리진 — 프론트가 실제 뜨는 오리진으로 좁혀 두면 안전.
# 예: https://hope-web.harvester.kr  또는  http://localhost:5173
# 여러 개면 콤마 분리 (백엔드 utils/http.js 는 현재 단일값만 지원, 필요 시 후속 PR)
CORS_ORIGIN=*

# --- AI 프록시 (Hope-AI FastAPI) ---
# 기본값(compose.harvester.yml)은 로컬 hope-ai 컨테이너 (http://hope-ai:8000).
# go-neung 을 계속 쓰려면 아래를 주석 해제.
# SPEECH_COACH_API_BASE=https://go-neung.activejang.com
SPEECH_TIMEOUT_MS=30000
SPEECH_RETRIES=1
SPEECH_MAX_BODY_BYTES=10485760
