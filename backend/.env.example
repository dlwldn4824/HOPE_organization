# HOPE backend environment

# HTTP port to bind to
PORT=4000

# Speech analysis upstream (Hope-AI deployed FastAPI)
SPEECH_COACH_API_BASE=https://go-neung.activejang.com

# SQLite file location (defaults to backend/data/hope.db)
# HOPE_DB_PATH=/var/lib/hope/hope.db

# Session token TTL in hours
HOPE_TOKEN_TTL_HOURS=24
